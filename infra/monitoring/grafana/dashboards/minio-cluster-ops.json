  },
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "MinIO scrape up",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "gridPos": {"h": 5, "w": 6, "x": 0, "y": 0},
      "targets": [{"expr": "up{job=\"minio\"}", "refId": "A"}]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "S3 request rate (if exposed)",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "gridPos": {"h": 8, "w": 18, "x": 6, "y": 0},
      "targets": [
        {
          "expr": "sum(rate(minio_s3_requests_total[5m])) by (api)",
          "legendFormat": "{{api}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Cluster usable free bytes",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "minio_cluster_capacity_usable_free_bytes",
          "legendFormat": "usable_free",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Cluster objects count",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [
        {
          "expr": "minio_cluster_objects_count",
          "legendFormat": "objects",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["minio", "object-storage"],
  "templating": {"list": []},
  "time": {"from": "now-6h", "to": "now"},
