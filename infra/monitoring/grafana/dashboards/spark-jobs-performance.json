{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {"type": "grafana", "uid": "-- Grafana --"},
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Batch compute health for Spark jobs. Aggregated by job_name only. Answers: which jobs are slow, which are failing.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Failure Ratio (24h)",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "gridPos": {"h": 5, "w": 8, "x": 0, "y": 0},
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 0.05},
              {"color": "red", "value": 0.1}
            ]
          },
          "color": {"mode": "thresholds"}
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(spark_job_failure_total[24h])) / clamp_min(sum(increase(spark_job_failure_total[24h])) + sum(increase(spark_job_success_total[24h])), 1)",
          "legendFormat": "failure ratio",
          "datasource": {"type": "prometheus", "uid": "Prometheus"}
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Jobs Run (24h)",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "gridPos": {"h": 5, "w": 8, "x": 8, "y": 0},
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(spark_job_success_total[24h])) + sum(increase(spark_job_failure_total[24h]))",
          "legendFormat": "jobs",
          "datasource": {"type": "prometheus", "uid": "Prometheus"}
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Active Failures (5m)",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "gridPos": {"h": 5, "w": 8, "x": 16, "y": 0},
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 1},
              {"color": "red", "value": 3}
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(spark_job_failure_total[5m]))",
          "legendFormat": "failures",
          "datasource": {"type": "prometheus", "uid": "Prometheus"}
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Job Duration: avg vs p95",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 5},
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"], "showLegend": true}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "lineWidth": 2,
            "spanNulls": true
          },
          "color": {"mode": "palette-classic"}
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(spark_job_duration_seconds_bucket[$__rate_interval])))",
          "legendFormat": "p95",
          "datasource": {"type": "prometheus", "uid": "Prometheus"}
        },
        {
          "refId": "B",
          "expr": "sum(rate(spark_job_duration_seconds_sum[$__rate_interval])) / clamp_min(sum(rate(spark_job_duration_seconds_count[$__rate_interval])), 1)",
          "legendFormat": "avg",
          "datasource": {"type": "prometheus", "uid": "Prometheus"}
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Success vs Failure Rate",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 5},
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"displayMode": "list", "placement": "bottom", "calcs": [], "showLegend": true}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "bars",
            "lineInterpolation": "linear",
            "fillOpacity": 40,
            "stacking": {"mode": "normal", "group": "A"}
          },
          "color": {"mode": "palette-classic"}
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "success"},
            "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "green"}}]
          },
          {
            "matcher": {"id": "byName", "options": "failed"},
            "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "red"}}]
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(spark_job_success_total[$__rate_interval]))",
          "legendFormat": "success",
          "datasource": {"type": "prometheus", "uid": "Prometheus"}
        },
        {
          "refId": "B",
          "expr": "sum(rate(spark_job_failure_total[$__rate_interval]))",
          "legendFormat": "failed",
          "datasource": {"type": "prometheus", "uid": "Prometheus"}
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Execution Time Trend by Job",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 14},
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"], "showLegend": true}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 5,
            "lineWidth": 1,
            "spanNulls": true
          },
          "color": {"mode": "palette-classic"}
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (job_name) (rate(spark_job_duration_seconds_sum[$__rate_interval])) / clamp_min(sum by (job_name) (rate(spark_job_duration_seconds_count[$__rate_interval])), 1)",
          "legendFormat": "{{job_name}}",
          "datasource": {"type": "prometheus", "uid": "Prometheus"}
        }
      ]
    },
    {
      "id": 7,
      "type": "table",
      "title": "Top Failing Jobs (24h)",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 14},
      "options": {
        "showHeader": true,
        "footer": {"show": false, "reducer": ["sum"], "fields": ""},
        "cellHeight": "sm"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {"align": "auto", "displayMode": "auto"},
          "color": {"mode": "thresholds"}
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "Value"},
            "properties": [
              {"id": "displayName", "value": "Failures (24h)"},
              {"id": "unit", "value": "short"},
              {"id": "custom.cellOptions", "value": {"type": "color-background", "mode": "gradient"}},
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {"color": "green", "value": null},
                    {"color": "orange", "value": 1},
                    {"color": "red", "value": 5}
                  ]
                }
              }
            ]
          }
        ]
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {"Time": true, "__name__": true, "instance": true, "job": true},
            "indexByName": {"job_name": 0, "Value": 1},
            "renameByName": {"job_name": "Job"}
          }
        }
      ],
      "targets": [
        {
          "refId": "A",
          "expr": "topk(10, sum by (job_name) (increase(spark_job_failure_total[24h])))",
          "format": "table",
          "instant": true,
          "datasource": {"type": "prometheus", "uid": "Prometheus"}
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["dataops", "spark", "compute"],
  "templating": {"list": []},
  "time": {"from": "now-24h", "to": "now"},
  "timepicker": {"refresh_intervals": ["10s", "30s", "1m", "5m", "15m"]},
  "timezone": "",
  "title": "Spark Jobs Performance",
  "uid": "dataops-spark-performance",
  "version": 1,
  "weekStart": ""
}
