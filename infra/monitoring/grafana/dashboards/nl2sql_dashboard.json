{
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "NL2SQL requests / sec",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        {
          "expr": "sum(rate(nl2sql_request_count_total[1m]))",
          "legendFormat": "RPS",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Total latency p95 (s)",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(nl2sql_total_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95 total",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "SQL execution latency p95 (s)",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(nl2sql_sql_execution_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95 SELECT",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Error rate (errors / request)",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "percentunit" } },
      "targets": [
        {
          "expr": "(sum(rate(nl2sql_sql_validation_errors_total[5m])) + sum(rate(nl2sql_sql_generation_errors_total[5m])) + sum(rate(nl2sql_sql_execution_errors_total[5m]))) / clamp_min(sum(rate(nl2sql_request_count_total[5m])), 1e-9)",
          "legendFormat": "errors / req",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Avg rows returned",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        {
          "expr": "sum(rate(nl2sql_rows_returned_sum[5m])) / clamp_min(sum(rate(nl2sql_rows_returned_count[5m])), 1e-9)",
          "legendFormat": "avg rows",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "SQL validation errors / sec",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "sum(rate(nl2sql_sql_validation_errors_total[5m]))",
          "legendFormat": "validation",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "SQL generation errors / sec",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "targets": [
        {
          "expr": "sum(rate(nl2sql_sql_generation_errors_total[5m]))",
          "legendFormat": "generation exhausted",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Retry rate (/ sec)",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "targets": [
        {
          "expr": "sum(rate(nl2sql_retry_total[5m]))",
          "legendFormat": "all retries",
          "refId": "A"
        },
        {
          "expr": "sum(rate(nl2sql_retry_total{stage=\"validation\"}[5m]))",
          "legendFormat": "validation",
          "refId": "B"
        },
        {
          "expr": "sum(rate(nl2sql_retry_total{stage=\"execution\"}[5m]))",
          "legendFormat": "execution",
          "refId": "C"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "RAG retrieved tables (avg count)",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        {
          "expr": "sum(rate(nl2sql_rag_retrieved_tables_count_sum[5m])) / clamp_min(sum(rate(nl2sql_rag_retrieved_tables_count_count[5m])), 1e-9)",
          "legendFormat": "avg tables",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Legacy request_latency p95 (s, compat)",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(nl2sql_request_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["nl2sql", "llm", "hr"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "title": "NL2SQL HR",
  "uid": "nl2sql-hr",
  "version": 2
}
