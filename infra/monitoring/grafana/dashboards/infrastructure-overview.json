{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Prometheus Up Targets",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "targets": [
        { "expr": "sum(up)", "refId": "A" }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Prometheus Scrape Health",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 0 },
      "targets": [
        { "expr": "avg_over_time(up[5m])", "legendFormat": "{{job}}", "refId": "A" }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Postgres OLAP Connections",
      "datasource": { "type": "postgres", "uid": "PGDWH" },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 8 },
      "targets": [
        { "format": "table", "rawSql": "SELECT COUNT(*) AS value FROM pg_stat_activity;", "refId": "A" }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Redis Connected Clients",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 6, "w": 16, "x": 8, "y": 8 },
      "targets": [
        { "expr": "redis_connected_clients", "legendFormat": "clients", "refId": "A" }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "cAdvisor up",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 14 },
      "targets": [{ "expr": "up{job=\"cadvisor\"}", "refId": "A" }]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Stack CPU (compose service)",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 14 },
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{container_label_com_docker_compose_service!=\"\"}[5m])) by (container_label_com_docker_compose_service)",
          "legendFormat": "{{container_label_com_docker_compose_service}}",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["infra", "overview"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "title": "Infrastructure Overview",
  "uid": "infra-overview",
  "version": 1
}
