{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {"type": "grafana", "uid": "-- Grafana --"},
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "CPU rate by compose service",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "gridPos": {"h": 9, "w": 24, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{container_label_com_docker_compose_service!=\"\"}[5m])) by (container_label_com_docker_compose_service)",
          "legendFormat": "{{container_label_com_docker_compose_service}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Memory working set by compose service",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "gridPos": {"h": 9, "w": 24, "x": 0, "y": 9},
      "targets": [
        {
          "expr": "sum(container_memory_working_set_bytes{container_label_com_docker_compose_service!=\"\"}) by (container_label_com_docker_compose_service)",
          "legendFormat": "{{container_label_com_docker_compose_service}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "cAdvisor scrape up",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "gridPos": {"h": 4, "w": 8, "x": 0, "y": 18},
      "targets": [{"expr": "up{job=\"cadvisor\"}", "refId": "A"}]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Container count (running)",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "gridPos": {"h": 6, "w": 16, "x": 8, "y": 18},
      "targets": [
        {
          "expr": "count(container_last_seen{container_label_com_docker_compose_service!=\"\"})",
          "legendFormat": "containers",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["cadvisor", "containers", "infra"],
  "templating": {"list": []},
  "time": {"from": "now-6h", "to": "now"},
  "title": "Stack containers (cAdvisor)",
  "uid": "stack-cadvisor",
  "version": 1
}
