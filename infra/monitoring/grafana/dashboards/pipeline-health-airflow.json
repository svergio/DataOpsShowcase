{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {"type": "grafana", "uid": "-- Grafana --"},
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Executive pipeline health for Airflow DAGs. Answers: what is broken, what is slow, what is failing.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "DAG Success Rate (24h)",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "gridPos": {"h": 5, "w": 6, "x": 0, "y": 0},
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "orange", "value": 0.9},
              {"color": "green", "value": 0.99}
            ]
          },
          "color": {"mode": "thresholds"}
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(dag_success_total[24h])) / clamp_min(sum(increase(dag_success_total[24h])) + sum(increase(dag_failure_total[24h])), 1)",
          "legendFormat": "success rate",
          "datasource": {"type": "prometheus", "uid": "Prometheus"}
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "DAG Runs (24h)",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "gridPos": {"h": 5, "w": 6, "x": 6, "y": 0},
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]},
          "color": {"mode": "thresholds"}
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(dag_success_total[24h])) + sum(increase(dag_failure_total[24h]))",
          "legendFormat": "runs",
          "datasource": {"type": "prometheus", "uid": "Prometheus"}
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Active Failures (last 5m)",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "gridPos": {"h": 5, "w": 6, "x": 12, "y": 0},
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 1},
              {"color": "red", "value": 3}
            ]
          },
          "color": {"mode": "thresholds"}
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(dag_failure_total[5m]))",
          "legendFormat": "failures",
          "datasource": {"type": "prometheus", "uid": "Prometheus"}
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Failed DAGs (24h)",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "gridPos": {"h": 5, "w": 6, "x": 18, "y": 0},
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 1},
              {"color": "red", "value": 5}
            ]
          },
          "color": {"mode": "thresholds"}
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "count(sum by (dag_id) (increase(dag_failure_total[24h])) > 0)",
          "legendFormat": "dags with failures",
          "datasource": {"type": "prometheus", "uid": "Prometheus"}
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "DAG Failure Count",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 5},
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["sum"], "showLegend": true}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "bars",
            "lineInterpolation": "linear",
            "fillOpacity": 30,
            "stacking": {"mode": "normal", "group": "A"}
          },
          "color": {"mode": "palette-classic"}
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (dag_id) (increase(dag_failure_total[$__rate_interval]))",
          "legendFormat": "{{dag_id}}",
          "datasource": {"type": "prometheus", "uid": "Prometheus"}
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Task Duration p95",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 5},
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["max", "mean"], "showLegend": true}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "lineWidth": 2,
            "spanNulls": true
          },
          "color": {"mode": "palette-classic"}
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, dag_id) (rate(task_duration_seconds_bucket[$__rate_interval])))",
          "legendFormat": "{{dag_id}}",
          "datasource": {"type": "prometheus", "uid": "Prometheus"}
        }
      ]
    },
    {
      "id": 7,
      "type": "table",
      "title": "Top 10 Failed Tasks (24h)",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 14},
      "options": {
        "showHeader": true,
        "footer": {"show": false, "reducer": ["sum"], "fields": ""},
        "cellHeight": "sm"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {"align": "auto", "displayMode": "auto"},
          "color": {"mode": "thresholds"}
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "Value"},
            "properties": [
              {"id": "displayName", "value": "Failures (24h)"},
              {"id": "unit", "value": "short"},
              {
                "id": "custom.cellOptions",
                "value": {"type": "color-background", "mode": "gradient"}
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {"color": "green", "value": null},
                    {"color": "orange", "value": 1},
                    {"color": "red", "value": 5}
                  ]
                }
              }
            ]
          }
        ]
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {"Time": true, "__name__": true, "instance": true, "job": true},
            "indexByName": {"dag_id": 0, "task_id": 1, "Value": 2},
            "renameByName": {"dag_id": "DAG", "task_id": "Task"}
          }
        }
      ],
      "targets": [
        {
          "refId": "A",
          "expr": "topk(10, sum by (dag_id, task_id) (increase(dag_failure_total[24h])))",
          "format": "table",
          "instant": true,
          "datasource": {"type": "prometheus", "uid": "Prometheus"}
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["dataops", "airflow", "pipelines"],
  "templating": {"list": []},
  "time": {"from": "now-24h", "to": "now"},
  "timepicker": {"refresh_intervals": ["10s", "30s", "1m", "5m", "15m"]},
  "timezone": "",
  "title": "Pipeline Health (Airflow)",
  "uid": "dataops-pipeline-health",
  "version": 1,
  "weekStart": ""
}
