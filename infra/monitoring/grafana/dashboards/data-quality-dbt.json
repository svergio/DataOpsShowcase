{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {"type": "grafana", "uid": "-- Grafana --"},
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "dbt layer runs via Pushgateway (dataops_dbt_*). Complements SQL checks in meta / dwh_dq.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "dbt run success ratio (24h)",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "gridPos": {"h": 5, "w": 8, "x": 0, "y": 0},
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "decimals": 2,
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "orange", "value": 0.9},
              {"color": "green", "value": 0.99}
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(dataops_dbt_run_outcome_total{status=\"success\"}[24h])) / clamp_min(sum(increase(dataops_dbt_run_outcome_total[24h])), 1)",
          "legendFormat": "success ratio",
          "datasource": {"type": "prometheus", "uid": "Prometheus"}
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Non-success dbt runs (24h)",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "gridPos": {"h": 5, "w": 8, "x": 8, "y": 0},
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 1},
              {"color": "red", "value": 5}
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(dataops_dbt_run_outcome_total{status!=\"success\"}[24h]))",
          "legendFormat": "non-success",
          "datasource": {"type": "prometheus", "uid": "Prometheus"}
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Reported test failures (last gauge push)",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "gridPos": {"h": 5, "w": 8, "x": 16, "y": 0},
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 1},
              {"color": "red", "value": 10}
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(dataops_dbt_test_failures_total)",
          "legendFormat": "failures",
          "datasource": {"type": "prometheus", "uid": "Prometheus"}
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "dbt run duration p95 by layer (target)",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 5},
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["max", "mean"], "showLegend": true}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "lineWidth": 2,
            "spanNulls": true
          },
          "color": {"mode": "palette-classic"}
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, target) (rate(dataops_dbt_run_duration_seconds_bucket[$__rate_interval])))",
          "legendFormat": "{{target}}",
          "datasource": {"type": "prometheus", "uid": "Prometheus"}
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Non-success dbt runs over time",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 5},
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["sum"], "showLegend": true}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "bars",
            "lineInterpolation": "linear",
            "fillOpacity": 30,
            "stacking": {"mode": "normal", "group": "A"}
          },
          "color": {"mode": "palette-classic"}
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (target) (increase(dataops_dbt_run_outcome_total{status!=\"success\"}[$__rate_interval]))",
          "legendFormat": "{{target}}",
          "datasource": {"type": "prometheus", "uid": "Prometheus"}
        }
      ]
    },
    {
      "id": 6,
      "type": "bargauge",
      "title": "Slowest layers (Top 10, p95)",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 14},
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "showUnfilled": true,
        "valueMode": "color",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "color": {"mode": "continuous-GrYlRd"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(10, max by (target) (histogram_quantile(0.95, sum by (le, target) (rate(dataops_dbt_run_duration_seconds_bucket[24h]))))",
          "legendFormat": "{{target}}",
          "instant": true,
          "datasource": {"type": "prometheus", "uid": "Prometheus"}
        }
      ]
    },
    {
      "id": 7,
      "type": "table",
      "title": "dbt test failure gauge by layer (target)",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 14},
      "options": {
        "showHeader": true,
        "footer": {"show": false, "reducer": ["sum"], "fields": ""},
        "cellHeight": "sm"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {"align": "auto", "displayMode": "auto"},
          "color": {"mode": "thresholds"}
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "Value"},
            "properties": [
              {"id": "displayName", "value": "Failures"},
              {"id": "unit", "value": "short"},
              {"id": "custom.cellOptions", "value": {"type": "color-background", "mode": "gradient"}},
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {"color": "green", "value": null},
                    {"color": "orange", "value": 1},
                    {"color": "red", "value": 5}
                  ]
                }
              }
            ]
          }
        ]
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {"Time": true, "__name__": true, "instance": true, "job": true},
            "indexByName": {"target": 0, "Value": 1},
            "renameByName": {"target": "Layer (target)"}
          }
        }
      ],
      "targets": [
        {
          "refId": "A",
          "expr": "topk(10, sum by (target) (dataops_dbt_test_failures_total))",
          "format": "table",
          "instant": true,
          "datasource": {"type": "prometheus", "uid": "Prometheus"}
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["dataops", "dbt", "data-quality"],
  "templating": {"list": []},
  "time": {"from": "now-24h", "to": "now"},
  "timepicker": {"refresh_intervals": ["10s", "30s", "1m", "5m", "15m"]},
  "timezone": "",
  "title": "Data Quality & dbt",
  "uid": "dataops-data-quality-dbt",
  "version": 1,
  "weekStart": ""
}
