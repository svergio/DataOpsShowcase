  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Active connections",
      "datasource": {"type": "postgres", "uid": "PGDWH"},
      "gridPos": {"h": 5, "w": 6, "x": 0, "y": 0},
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT COUNT(*)::bigint AS value FROM pg_stat_activity WHERE state = 'active';",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Waiting locks (not granted)",
      "datasource": {"type": "postgres", "uid": "PGDWH"},
      "gridPos": {"h": 5, "w": 6, "x": 6, "y": 0},
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT COUNT(*)::bigint AS value FROM pg_locks WHERE NOT granted;",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "DB size (bytes)",
      "datasource": {"type": "postgres", "uid": "PGDWH"},
      "gridPos": {"h": 5, "w": 6, "x": 12, "y": 0},
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT pg_database_size(current_database())::bigint AS value;",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "table",
      "title": "Largest relations in dwh_marts",
      "datasource": {"type": "postgres", "uid": "PGDWH"},
      "gridPos": {"h": 12, "w": 24, "x": 0, "y": 5},
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT relname AS table_name, pg_total_relation_size(c.oid)::bigint AS total_bytes FROM pg_class c JOIN pg_namespace n ON n.oid = c.relnamespace WHERE n.nspname = 'dwh_marts' AND c.relkind = 'r' ORDER BY total_bytes DESC LIMIT 25;",
          "refId": "A"
        }
      ]
    }
  ],
