# Image tags
POSTGRES_IMAGE_TAG=16-alpine
REDIS_IMAGE_TAG=7-alpine
KAFKA_IMAGE_TAG=7.6.1
MINIO_IMAGE_TAG=latest
SPARK_IMAGE_TAG=3.5.1
AIRFLOW_IMAGE_TAG=2.9.3-python3.11
DBT_IMAGE_TAG=1.8.2
SUPERSET_IMAGE_TAG=latest
JUPYTER_IMAGE_TAG=latest
PROMETHEUS_IMAGE_TAG=v2.54.1
GRAFANA_IMAGE_TAG=11.1.4

# Postgres OLTP
PG_OLTP_USER=oltp_user
PG_OLTP_PASSWORD=oltp_pass
PG_OLTP_DB=techmart_oltp
PG_OLTP_PORT=5433

# Postgres OLAP (DWH)
PG_OLAP_USER=olap_user
PG_OLAP_PASSWORD=olap_pass
PG_OLAP_DB=techmart_dwh
PG_OLAP_PORT=5434

# Postgres MetaDB
PG_META_USER=meta_user
PG_META_PASSWORD=meta_pass
PG_META_DB=metadb
PG_META_PORT=5435

# Airflow
AIRFLOW_DB_NAME=airflow
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_WEBSERVER_SECRET_KEY=change_me_airflow_secret
# AIRFLOW_PORT — раньше проброс UI; Web UI только через ingress (INGRESS_PORT)
AIRFLOW_UID=50000

# Spark privacy (staging anonymization). Use a strong secret in production.
SPARK_PRIVACY_SALT=change-me-in-production
SPARK_JOB_ENV=production

# Superset
SUPERSET_DB_NAME=superset
SUPERSET_ADMIN_USER=admin
SUPERSET_ADMIN_PASSWORD=admin
SUPERSET_SECRET_KEY=change_me_superset_secret
# SUPERSET_PORT не публикуется; UI через INGRESS_URL/superset/
# Четвёртый дашборд (финансы демо): таблицы demo_fin.* в postgres_olap после DAG dag_spark_hive_finance_cbr_demo (Spark пишет в Postgres OLAP, не в Hive)
# Airflow Variable (опционально): SPARK_PG_FINANCE_LOOKBACK_DAYS — глубина дней для DAG выше; при отсутствии используется SPARK_HIVE_FINANCE_LOOKBACK_DAYS, иначе 400

# MinIO
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio123
MINIO_PORT=9000
# Консоль MinIO только за ingress (/minio-console/); см. MINIO_BROWSER_REDIRECT_URL

# Redis
REDIS_PORT=6379

# Kafka
KAFKA_PORT=9092

# Spark
SPARK_MASTER_PORT=7077
# Spark UI только за ingress (/spark-master/, /spark-worker/)

# MLflow
# MLFLOW UI только за ingress (/mlflow/)
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_EXPERIMENT_NAME=DataOpsShowcaseSpark
MLFLOW_MODEL_NAME=orders_revenue_regressor
MLFLOW_BACKEND_STORE_URI=postgresql+psycopg2://meta_user:meta_pass@postgres_metadb:5432/mlflow
MLFLOW_S3_ENDPOINT_URL=http://minio:9000
MLFLOW_ARTIFACT_ROOT=s3://mlflow-artifacts
AWS_DEFAULT_REGION=us-east-1

# Monitoring (Prometheus/Grafana UI только через ingress)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Jupyter через ingress /jupyter/ (порт контейнера не публикуется)
JUPYTER_TOKEN=changeme

# Data generator — non-secret "company profile" defaults: configs/generators/company.generator.json
# Merge order before per-field env: code baseline -> file JSON -> GENERATOR_SETTINGS_JSON -> meta DB (if enabled)
# Env overrides merged profile when non-empty for that field (empty string falls back to merged).
# Docker: variables must appear in docker-compose.yml data_generator.environment (or env_file) to reach the container.
GENERATOR_CONFIG_DIR=/app/configs/generators
GENERATOR_SETTINGS_FILE=/app/configs/generators/company.generator.json
# GENERATOR_SETTINGS_JSON={"tick_seconds":5}
GENERATOR_USE_META_STORE=false
# GENERATOR_META_DSN=postgresql://${PG_META_USER}:${PG_META_PASSWORD}@postgres_metadb:5432/${PG_META_DB}
GENERATOR_PROFILE=default
# При старте data_generator: применить DDL расширений OLTP из файла (старый Docker-том Postgres без init-скриптов — см. docs/SETUP.md)
# OLTP_EXTENSIONS_SQL=/app/sql/02b_oltp_marketing_hr_finance.sql
# Examples: GENERATOR_TICK_SECONDS=5  GENERATOR_ENABLE_KAFKA=false
# Integration tests (host reaches compose ports): pytest tests/integration -m integration
# GENERATOR_IT_OLTP_DSN=postgresql://oltp_user:oltp_pass@localhost:55432/techmart_oltp
# GENERATOR_IT_REDIS_URL=redis://localhost:6379/0
# GENERATOR_IT_KAFKA_BOOTSTRAP=localhost:9092
# GENERATOR_IT_MINIO_ENDPOINT=localhost:9000
# GENERATOR_IT_MINIO_ACCESS_KEY=minio
# GENERATOR_IT_MINIO_SECRET_KEY=minio123

# Kafka topics
KAFKA_TOPIC_CLICKSTREAM=techmart.events.clickstream
KAFKA_TOPIC_ORDERS=techmart.events.orders
KAFKA_TOPIC_PAYMENTS=techmart.payments.transactions
KAFKA_TOPIC_SHIPMENTS=techmart.shipments.tracking
KAFKA_TOPIC_MARKETING_EMAIL=techmart.marketing.email_events
KAFKA_TOPIC_SEO_ORGANIC=techmart.seo.organic_sessions
KAFKA_TOPIC_HR_TIME_TRACKING=techmart.hr.time_tracking
KAFKA_TOPIC_FEATURE_FLAG_EVAL=techmart.features.evaluated

# Redis pub/sub channels and streams
REDIS_CHANNEL_ORDERS=techmart:orders
REDIS_CHANNEL_PAYMENTS=techmart:payments
REDIS_CHANNEL_CLICKSTREAM=techmart:clickstream
REDIS_STREAM_ORDERS=techmart:stream:orders

# MinIO buckets and prefixes
MINIO_BUCKET_RAW=techmart-data
MINIO_PREFIX_PAYMENTS=raw/payments
MINIO_PREFIX_RETURNS=raw/returns
MINIO_PREFIX_CATALOG=raw/product_catalog

# dbt REST runner (Airflow/kubernetes-style triggers; см. services/dbt_rest)
DBT_REST_BASE_URL=http://dbt-rest:8580
DBT_REST_TOKEN=
# Метаданные прогонов dbt-rest (схема dbt_rest в postgres_metadb). В compose задаётся через DBT_REST_DB_DSN; локально:
# DBT_REST_DB_DSN=postgresql://meta_user:meta_pass@localhost:5435/metadb

# Unified ingress (единственная HTTP-точка для веб-UI; см. docs/WEB_UI_ACCESS.md)
# Важно: INGRESS_BASE_URL (и порт INGRESS_PORT) должны совпадать с тем, что вы вводите в браузере.
# Иначе Superset отдаст шапку с #app, но пустой контент, битые ссылки /superset/superset/... и сессия не склеится.
# Пример: при INGRESS_PORT=8090 открывайте http://localhost:8090/...; если у вас ингресс на 80, задайте INGRESS_BASE_URL=http://localhost и INGRESS_PORT=80, перезапустите superset.
INGRESS_PORT=8090
INGRESS_BASE_URL=http://localhost:8090

# MinIO: публичные URL для консоли/API с хоста. Меняйте вместе с MINIO_PORT и INGRESS_BASE_URL в compose.
# MINIO_SERVER_URL по умолчанию = http://localhost:${MINIO_PORT} (подставляется в docker-compose).
# MINIO_BROWSER_REDIRECT_URL по умолчанию = ${INGRESS_BASE_URL}/minio-console/
# MINIO_BROWSER_REDIRECT_URL=http://localhost:8090/minio-console/
# MINIO_SERVER_URL=http://localhost:9000

# Node-RED (образ и учётка админки; см. services/node_red)
NODE_RED_IMAGE_TAG=4.1.8-22
NODE_RED_ADMIN_USER=admin
NODE_RED_ADMIN_PASSWORD=changeme

# NL2SQL app (services/nl2sql_app)
NL2SQL_DB_URL=postgresql+psycopg2://olap_user:olap_pass@postgres_olap:5432/techmart_dwh
# models:/<name>/latest требует хотя бы одной зарегистрированной версии в MLflow UI (пустое имя модели без Versions недостаточно).
NL2SQL_MODEL_URI=models:/nl2sql_qwen/latest
NL2SQL_MODEL_NAME=nl2sql_qwen
# true — при старте залогировать pyfunc в реестр (долго, нужен образ/ресурсы); иначе зарегистрируйте версию вручную в MLflow.
NL2SQL_AUTO_LOG_MODEL=false
NL2SQL_BASE_MODEL_ID=Qwen/Qwen2.5-3B-Instruct
NL2SQL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
NL2SQL_RAG_TOP_K=3
NL2SQL_MAX_NEW_TOKENS=256
NL2SQL_TEMPERATURE=0.0
NL2SQL_MODEL_DEVICE=cpu
NL2SQL_DEBUG=false
# false — скрыть GET /metrics (404); Prometheus в compose по умолчанию скрейпит nl2sql_app
NL2SQL_EXPOSE_METRICS=true

# Apache Atlas (основной docker-compose.yml; JVM heap через ATLAS_JAVA_OPTS)
ATLAS_JAVA_OPTS=-Xmx3G -Xms1G
SBURN_APACHE_ATLAS_TAG=latest
ATLAS_REST_URL=http://atlas_server:21000/
# Legacy: раньше ATLAS_EXTERNAL_NETWORK использовали для overlay; в текущем стеке не требуется.

# Schema Registry + Debezium Kafka Connect (основной compose)
CP_SCHEMA_REGISTRY_TAG=7.6.1
DEBEZIUM_CONNECT_TAG=2.5
DEBEZIUM_GROUP_ID=debezium-cluster
DEBEZIUM_CONNECT_HEALTH_URL=http://debezium_connect:8083/

# Replication users for Debezium (must match services/postgres/cdc/*.sh and configs/debezium/*.json)
DEBEZIUM_OLTP_PASSWORD=debezium_oltp_pass
DEBEZIUM_OLAP_PASSWORD=debezium_olap_pass
DEBEZIUM_META_PASSWORD=debezium_meta_pass

# Postgres reflect script (host path to OLTP for local runs)
# PG_REFLECT_DSN=postgresql://oltp_user:oltp_pass@localhost:5433/techmart_oltp
