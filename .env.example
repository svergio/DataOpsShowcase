# Image tags
POSTGRES_IMAGE_TAG=16-alpine
REDIS_IMAGE_TAG=7-alpine
KAFKA_IMAGE_TAG=7.6.1
MINIO_IMAGE_TAG=latest
SPARK_IMAGE_TAG=3.5.1
AIRFLOW_IMAGE_TAG=2.9.3-python3.11
DBT_IMAGE_TAG=1.8.2
SUPERSET_IMAGE_TAG=latest
JUPYTER_IMAGE_TAG=latest
PROMETHEUS_IMAGE_TAG=v2.54.1
GRAFANA_IMAGE_TAG=11.1.4

# Postgres OLTP
PG_OLTP_USER=oltp_user
PG_OLTP_PASSWORD=oltp_pass
PG_OLTP_DB=techmart_oltp
PG_OLTP_PORT=5433

# Postgres OLAP (DWH)
PG_OLAP_USER=olap_user
PG_OLAP_PASSWORD=olap_pass
PG_OLAP_DB=techmart_dwh
PG_OLAP_PORT=5434

# Postgres MetaDB
PG_META_USER=meta_user
PG_META_PASSWORD=meta_pass
PG_META_DB=metadb
PG_META_PORT=5435

# Airflow
AIRFLOW_DB_NAME=airflow
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_WEBSERVER_SECRET_KEY=change_me_airflow_secret
AIRFLOW_PORT=8080
AIRFLOW_UID=50000

# Superset
SUPERSET_DB_NAME=superset
SUPERSET_ADMIN_USER=admin
SUPERSET_ADMIN_PASSWORD=admin
SUPERSET_SECRET_KEY=change_me_superset_secret
SUPERSET_PORT=8088

# MinIO
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio123
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# Redis
REDIS_PORT=6379

# Kafka
KAFKA_PORT=9092

# Spark
SPARK_MASTER_PORT=7077
SPARK_MASTER_UI_PORT=8082
SPARK_WORKER_UI_PORT=8083

# MLflow
MLFLOW_PORT=5001
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_EXPERIMENT_NAME=DataOpsShowcaseSpark
MLFLOW_MODEL_NAME=orders_revenue_regressor
MLFLOW_BACKEND_STORE_URI=postgresql+psycopg2://meta_user:meta_pass@postgres_metadb:5432/mlflow
MLFLOW_S3_ENDPOINT_URL=http://minio:9000
MLFLOW_ARTIFACT_ROOT=s3://mlflow-artifacts
AWS_DEFAULT_REGION=us-east-1

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Jupyter
JUPYTER_PORT=8888
JUPYTER_TOKEN=changeme

# Data generator — non-secret "company profile" defaults: configs/generators/company.generator.json
# Merge order before per-field env: code baseline -> file JSON -> GENERATOR_SETTINGS_JSON -> meta DB (if enabled)
# Env overrides merged profile when non-empty for that field (empty string falls back to merged).
# Docker: variables must appear in docker-compose.yml data_generator.environment (or env_file) to reach the container.
GENERATOR_CONFIG_DIR=/app/configs/generators
GENERATOR_SETTINGS_FILE=/app/configs/generators/company.generator.json
# GENERATOR_SETTINGS_JSON={"tick_seconds":5}
GENERATOR_USE_META_STORE=false
# GENERATOR_META_DSN=postgresql://${PG_META_USER}:${PG_META_PASSWORD}@postgres_metadb:5432/${PG_META_DB}
GENERATOR_PROFILE=default
# Examples: GENERATOR_TICK_SECONDS=5  GENERATOR_ENABLE_KAFKA=false
# Integration tests (host reaches compose ports): pytest tests/integration -m integration
# GENERATOR_IT_OLTP_DSN=postgresql://oltp_user:oltp_pass@localhost:55432/techmart_oltp
# GENERATOR_IT_REDIS_URL=redis://localhost:6379/0
# GENERATOR_IT_KAFKA_BOOTSTRAP=localhost:9092
# GENERATOR_IT_MINIO_ENDPOINT=localhost:9000
# GENERATOR_IT_MINIO_ACCESS_KEY=minio
# GENERATOR_IT_MINIO_SECRET_KEY=minio123

# Kafka topics
KAFKA_TOPIC_CLICKSTREAM=techmart.events.clickstream
KAFKA_TOPIC_ORDERS=techmart.events.orders
KAFKA_TOPIC_PAYMENTS=techmart.payments.transactions
KAFKA_TOPIC_SHIPMENTS=techmart.shipments.tracking

# Redis pub/sub channels and streams
REDIS_CHANNEL_ORDERS=techmart:orders
REDIS_CHANNEL_PAYMENTS=techmart:payments
REDIS_CHANNEL_CLICKSTREAM=techmart:clickstream
REDIS_STREAM_ORDERS=techmart:stream:orders

# MinIO buckets and prefixes
MINIO_BUCKET_RAW=techmart-data
MINIO_PREFIX_PAYMENTS=raw/payments
MINIO_PREFIX_RETURNS=raw/returns
MINIO_PREFIX_CATALOG=raw/product_catalog

# dbt REST runner (custom service that triggers dbt jobs via HTTP)
DBT_REST_BASE_URL=http://dbt-rest:8580
DBT_REST_TOKEN=

# dbt-web (Flask: UI at /dbt-web, JSON API at /api/v1 on same process)
DBT_WEB_BACKEND_PORT=8010
DBT_WEB_BASE_URL=http://dbt-web-backend:8010
DBT_WEB_SECRET_KEY=change-me-dbt-web
DBT_WEB_AUTH_USER=admin
DBT_WEB_AUTH_PASSWORD=admin
DBT_WEB_TOKEN=

# Unified ingress (nginx reverse proxy)
INGRESS_PORT=8090
INGRESS_BASE_URL=http://localhost:8090
