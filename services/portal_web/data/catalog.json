{
  "version": 1,
  "init_containers": ["airflow_init", "superset_init"],
  "optional_graph_containers": ["data_generator"],
  "web_ui_services": [
    {
      "id": "airflow",
      "name": "Airflow",
      "route": "/airflow/",
      "purpose": "Веб-интерфейс DAG, расписание по датасетам, логи задач (см. docs/PIPELINES.md).",
      "container": "airflow_webserver",
      "probe_url": "http://airflow_webserver:8080/health"
    },
    {
      "id": "dbt-docs",
      "name": "dbt Docs",
      "route": "/dbt/",
      "purpose": "Статический сайт из `dbt docs generate` (артефакты в `dbt/target/`, отдаёт ingress). Нужен успешный прогон DAG с docs.",
      "container": "dataops_ingress",
      "probe_url": "http://dataops_ingress/dbt/"
    },
    {
      "id": "mlflow",
      "name": "MLflow",
      "route": "/mlflow/",
      "purpose": "Эксперименты и артефакты ML; связка со Spark-тренировками в каталоге DAG.",
      "container": "mlflow",
      "probe_url": "http://mlflow:5000/"
    },
    {
      "id": "grafana",
      "name": "Grafana",
      "route": "/grafana/",
      "purpose": "Дашборды по метрикам Prometheus и сигналам пайплайнов.",
      "container": "grafana",
      "probe_url": "http://grafana:3000/api/health"
    },
    {
      "id": "superset",
      "name": "Superset",
      "route": "/superset/",
      "purpose": "BI и SQL над витринами OLAP (см. docs/SUPERSET.md).",
      "container": "superset",
      "probe_url": "http://superset:8088/superset/health"
    },
    {
      "id": "jupyter",
      "name": "Jupyter",
      "route": "/jupyter/",
      "purpose": "Ноутбуки в сети стека; base_url=/jupyter/ (docs/WEB_UI_ACCESS.md).",
      "container": "jupyterhub",
      "probe_url": "http://jupyterhub:8888/jupyter/"
    },
    {
      "id": "node-red",
      "name": "Node-RED",
      "route": "/node-red/",
      "purpose": "Low-code потоки и HTTP-интеграции; UI и ноды под префиксом /node-red/ (логин в .env: NODE_RED_ADMIN_*).",
      "container": "node_red",
      "probe_url": "http://node_red:1880/node-red/"
    },
    {
      "id": "nl2sql-app",
      "name": "NL2SQL HR",
      "route": "/nl2sql/",
      "purpose": "Чат-интерфейс NL2SQL для HR-данных DWH (RAG + локальная Qwen через MLflow pyfunc).",
      "container": "nl2sql_app",
      "probe_url": "http://nl2sql_app:8060/health"
    },
    {
      "id": "prometheus",
      "name": "Prometheus",
      "route": "/prometheus/",
      "purpose": "Сбор и запрос метрик; UI за ingress с префиксом /prometheus/.",
      "container": "prometheus",
      "probe_url": "http://prometheus:9090/-/healthy"
    },
    {
      "id": "pushgateway",
      "name": "Pushgateway",
      "route": "/pushgateway/",
      "purpose": "Приём push-метрик от короткоживущих задач (Spark и др.).",
      "container": "pushgateway",
      "probe_url": "http://pushgateway:9091/-/healthy"
    },
    {
      "id": "spark-master",
      "name": "Spark Master",
      "route": "/spark-master/",
      "purpose": "Веб UI мастера Spark standalone.",
      "container": "spark_master",
      "probe_url": "http://spark_master:8080/"
    },
    {
      "id": "spark-worker",
      "name": "Spark Worker",
      "route": "/spark-worker/",
      "purpose": "Веб UI воркера: executors и задачи.",
      "container": "spark_worker",
      "probe_url": "http://spark_worker:8081/"
    },
    {
      "id": "minio-console",
      "name": "MinIO Console",
      "route": "/minio-console/",
      "purpose": "Консоль объектного хранилища (сырые зоны, артефакты). S3 API с хоста — отдельный порт MINIO_PORT.",
      "container": "minio",
      "probe_url": "http://minio:9001/"
    },
    {
      "id": "atlas",
      "name": "Apache Atlas",
      "route": "/atlas/",
      "purpose": "Метаданные и lineage: веб-UI и API за ingress (основной compose). Первый старт может занять много минут.",
      "container": "atlas_server",
      "probe_url": "http://atlas_server:21000/"
    }
  ],
  "api_and_tools": [
    {
      "id": "schema-registry",
      "name": "Schema Registry (REST)",
      "route": "/schema-registry/",
      "purpose": "API схем (JSON). Доступно через ingress; не веб-UI.",
      "checklist_what": "API схем (JSON), Confluent-compatible.",
      "checklist_how": "с хоста /schema-registry/, внутри schema_registry:8081.",
      "container": "schema_registry",
      "probe_url": "http://schema_registry:8081/subjects",
      "kind": "ingress_api"
    },
    {
      "id": "kafka-connect",
      "name": "Kafka Connect / Debezium (REST)",
      "route": "/kafka-connect/",
      "purpose": "REST Kafka Connect/Debezium: статус кластера и коннекторы.",
      "checklist_what": "REST Kafka Connect/Debezium.",
      "checklist_how": "с хоста /kafka-connect/, внутри debezium_connect:8083.",
      "container": "debezium_connect",
      "probe_url": "http://debezium_connect:8083/connectors",
      "kind": "ingress_api"
    },
    {
      "id": "airflow-api",
      "name": "Airflow REST API v1",
      "route": "/airflow/api/v1/",
      "purpose": "Открытое HTTP API: DAG runs, задачи, OpenAPI. За ingress тот же префикс /airflow/, что и UI. Basic-auth или сессия по политике RBAC Airflow.",
      "checklist_what": "REST v1 (например /airflow/api/v1/version, openapi).",
      "checklist_how": "с хоста по INGRESS_BASE_URL + /airflow/api/v1/; внутри airflow_webserver:8080/airflow/api/v1/.",
      "container": "airflow_webserver",
      "probe_url": "http://airflow_webserver:8080/airflow/health",
      "kind": "ingress_api"
    },
    {
      "id": "dbt-rest",
      "name": "dbt REST (FastAPI, запуск dbt)",
      "route": "",
      "purpose": "Запуск dbt-run'ов (POST /runs, /jobs/run/*), плюс статус, логи и артефакты. Публичного JSON API для метаданных dbt через ingress нет.",
      "checklist_what": "Сервис запуска dbt-run'ов и выдачи статуса/логов.",
      "checklist_how": "внутри compose: dbt-rest:8580 (POST /runs, GET /runs/{id}).",
      "container": "dbt-rest",
      "probe_url": "http://dbt_rest:8580/health/live",
      "kind": "internal_only"
    },
    {
      "id": "pg-oltp",
      "name": "PostgreSQL OLTP",
      "route": "",
      "purpose": "OLTP БД внутри сети compose: postgres_oltp:5432.",
      "checklist_what": "Транзакционная БД OLTP.",
      "checklist_how": "внутри compose: postgres_oltp:5432.",
      "container": "postgres_oltp",
      "probe_url": null,
      "kind": "internal_only"
    },
    {
      "id": "pg-olap",
      "name": "PostgreSQL OLAP (DWH)",
      "route": "",
      "purpose": "DWH БД внутри сети compose: postgres_olap:5432.",
      "checklist_what": "Аналитическая БД DWH (raw/staging/vault/marts).",
      "checklist_how": "внутри compose: postgres_olap:5432.",
      "container": "postgres_olap",
      "probe_url": null,
      "kind": "internal_only"
    },
    {
      "id": "kafka-internal",
      "name": "Kafka broker",
      "route": "",
      "purpose": "Внутренний брокер событий: kafka:9092.",
      "checklist_what": "Брокер событий Kafka.",
      "checklist_how": "внутри compose: kafka:9092.",
      "container": "kafka",
      "probe_url": null,
      "kind": "internal_only"
    },
    {
      "id": "minio-s3",
      "name": "MinIO S3 API",
      "route": "",
      "purpose": "S3 API: minio:9000 в compose, localhost:MINIO_PORT с хоста.",
      "checklist_what": "S3-совместимый API объектного хранилища.",
      "checklist_how": "внутри minio:9000, с хоста localhost:MINIO_PORT.",
      "container": "minio",
      "probe_url": null,
      "kind": "internal_only"
    }
  ],
  "graph_nodes": [
    {"id": "dataops_ingress", "label_ru": "Ingress (nginx)", "container": "dataops_ingress", "shape_kind": "gateway", "group": 0, "is_init": false},
    {"id": "portal_web", "label_ru": "Портал", "container": "portal_web", "shape_kind": "web_app", "group": 0, "is_init": false},
    {"id": "airflow_webserver", "label_ru": "Airflow Web", "container": "airflow_webserver", "shape_kind": "orchestrator", "group": 1, "is_init": false},
    {"id": "airflow_scheduler", "label_ru": "Airflow Scheduler", "container": "airflow_scheduler", "shape_kind": "orchestrator", "group": 1, "is_init": false},
    {"id": "airflow_triggerer", "label_ru": "Airflow Triggerer", "container": "airflow_triggerer", "shape_kind": "orchestrator", "group": 1, "is_init": false},
    {"id": "airflow_init", "label_ru": "Airflow init", "container": "airflow_init", "shape_kind": "batch", "group": 1, "is_init": true},
